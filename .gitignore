  # Node modules
  client/node_modules/
  server/node_modules/

  # Build outputs
  client/dist/
  server/dist/

  # Environment files
  client/.env
  client/.env.local
  client/.env.production
  server/.env
  server/.env.local
  server/.env.production
  *.env

  # Allow example env files
  !client/.env.example
  !server/.env.example

  # Logs
  logs/
  *.log
  npm-debug.log*
  yarn-debug.log*
  yarn-error.log*
  pnpm-debug.log*
  lerna-debug.log*

  # Editor and OS files
  .vscode/
  .idea/
  .DS_Store
  *.suo
  *.ntvs*
  *.njsproj
  *.sln
  *.sw?

  # TypeScript cache
  client/*.tsbuildinfo
  server/*.tsbuildinfo
